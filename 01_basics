# Armstrong Or not
num=int(input("Enter a number :"))
sum=0
n=len(str(num))
temp=num
while(temp>0):
    digit=temp%10
    sum+=digit**n
    temp=temp//10
if sum==num:
    print("Armstrong number .")
else:
    print("Not a armstrong number .")

